{
  "layer": "top", "position": "top",
  "modules-left": ["custom/logo", "clock", "custom/weather", "memory", "cpu", "temperature", "hyprland/window" ],
  "modules-center": [  "hyprland/workspaces"],
  "modules-right": ["tray",  "pulseaudio", "network",  "battery", "custom/shutdown" ],
  "reload_style_on_change":true,

  "custom/logo": {
    "format": "ґ▒ДЕ",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "яЖТ",
      "default": "яТк" 
    },
    "persistent-workspaces": {
      "*": [ 2, 3, 4, 5, 6 ]
    }
},

"idle_inhibitor":{
  "format": "<span font='12'>{icon} </span>",
  "format-icons": {
    "activated":"ґ░ИИ",
    "deactivated":"ґ░ИЙ"
  }
},

"custom/weather": {
  "format": "{}",
  "return-type": "json",
  "exec": "~/.config/waybar/scripts/weather.sh",
  "interval": 10,
  "on-click": "zen https://wttr.in"
},

"custom/clipboard":{
  "format":"ю╡╗",
  "on-click": "cliphist list | rofi -dmenu | cliphist decode | wl-copy",
  "interval":86400
},


"clock": {
      "format": "{:%I:%M:%S %p}",
      "interval":1,
      "tooltip-format": "\n<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "calendar-weeks-pos": "right",
      "today-format": "<span color='#7645AD'><b><u>{}</u></b></span>",
      "format-calendar": "<span color='#aeaeae'><b>{}</b></span>",
      "format-calendar-weeks": "<span color='#aeaeae'><b>W{:%V}</b></span>",
      "format-calendar-weekdays": "<span color='#aeaeae'><b>{}</b></span>"
      },

  "bluetooth": {
  "format-on": "яКУ",
  "format-off": "",
  "format-disabled": "ґ░В▓",
  "format-connected": "ґ░В┤",
  "format-connected-battery": "{device_battery_percentage}% ґ░В┤",
  "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
  "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
  "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
  "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
  "on-click": "rofi-bluetooth",
 }, 

"network": {
      "format-wifi": "яЗл ",
      "format-ethernet":"ю╝Й ",
      "format-disconnected": "юмБ",
      "tooltip-format": "{ipaddr}",
      "tooltip-format-wifi": "{essid} ({signalStrength}%) яЗл | {ipaddr}",
      "tooltip-format-ethernet": "{ifname} ЁЯЦз | {ipaddr}",
      "on-click": "networkmanager_dmenu"
    },

"battery": {
    "interval":1,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}%  {icon} ",
        "format-charging": "{capacity}% ґ░ВД ",
        "format-plugged": "{capacity}% ґ░ВД юмн",
        "format-alt": "{time} {icon}",
            "format-icons": [
          "ґ░Б╗",
          "ґ░Б╝",
          "ґ░Б╛",
          "ґ░ВА",
          "ґ░ВВ",
          "ґ░Б╣"
        ],
    },
"backlight": {
  "device": "intel_backlight",
  "format": "<span font='12'>{icon}</span>",
  "format-icons": [
    "юПХ",
    "юПЦ",
    "юПЧ",
    "юПШ",
    "юПЪ",
    "юПЫ",
    "юПЬ",
    "юПЭ",
    "юПЮ",
    "юПЯ",
  ],
  "on-scroll-down": "light -A 10",
  "on-scroll-up": "light -U 10",
  "smooth-scrolling-threshold": 1
  },

 "disk": {
    "interval": 30,
    "format": "яЗА  {percentage_used}%",
    "path": "/"
  },

  "custom/colorpicker": {
    "format": "{}",
    "return-type": "json",
    "interval": "once",
    "exec": "~/.config/waybar/scripts/colorpicker.sh -j",
    "on-click": "sleep 1 && ~/.config/waybar/scripts/colorpicker.sh",
    "signal": 1
  },

  "cpu": {
      "interval": 1,
      "format": "ю║Ь {usage}%",
      "min-length": 6,
      "max-length": 6,
      "format-icons": ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ"],
 },

"memory": {
  "format": "юЙж {percentage}%"
},

 "hyprland/window": {
    "format": "( {class} )",
    "rewrite": {
         "(.*) - Mozilla Firefox": "ЁЯМО $1",
         "(.*) - zsh": "> [$1]"
    }
},

"temperature": {
  "format": "яЛЙ {temperatureC}┬░C",            
  "format-critical": "яЛЗ {temperatureC}┬░C",
  "interval": 1,
  "critical-threshold": 80,
  "on-click": "foot btop",
 },

"pulseaudio": {
  "format": "{volume}% {icon}",
  "format-bluetooth":"ґ░В░",
  "format-muted": "<span font='12'>юмд</span>",
  "format-icons": {
    "headphones": "яАе",
    "bluetooth": "ґ░е░",
    "handsfree": "яАе",
    "headset": "ґ▒бм",
    "phone": "яВХ",
    "portable": "яВХ",
    "car": "яЖ╣",
    "default": ["ЁЯХи","ЁЯХй","ЁЯХк"]
  },
  "justify": "center",
  "on-click": "amixer sset Master toggle",
  "on-click-right": "pavucontrol",
  "tooltip-format": "{icon}  {volume}%"
},

"custom/shutdown": {
  "format": "ґ░Ре ",
  "on-click": "shutdown now",
  "on-right-click": "reboot"
},

"jack": {
    "format": "{} ґ▒ОФ",
    "format-xrun": "{xruns} xruns",
    "format-disconnected": "DSP off",
    "realtime": true
},

"tray": {
    "icon-size": 14,
    "spacing": 10
},

"upower": {
    "show-icon": false,
    "hide-if-empty": true,
    "tooltip": true,
    "tooltip-spacing": 20
},

  "custom/powerDraw": {
    "format": "{}",
    "interval": 1,
    "exec": "~/.config/waybar/scripts/powerdraw.sh",
    "return-type": "json"
  }

}

